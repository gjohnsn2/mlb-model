# MLB Model Environment Variables
# Copy this file to .env and fill in your credentials

# The Odds API (https://the-odds-api.com)
# Required for odds data. Shared with CBB model — same API key.
# $59/mo (100K credits) sufficient for MLB + CBB daily pipeline.
ODDS_API_KEY=your_odds_api_key_here

# Override date for the pipeline (optional)
# MLB_DATE=2026-04-15

# --- Everything below is FREE, no keys needed ---
# MLB Stats API: no auth (statsapi.mlb.com)
# Statcast/pybaseball: no auth
# Baseball Reference: no auth
# Open-Meteo weather: no auth (open-meteo.com)
# Retrosheet: no auth (bulk CSV downloads)
