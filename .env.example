# MLB Model Environment Variables
# Copy this file to .env and fill in your credentials

# The Odds API (https://the-odds-api.com)
# Required for odds data. Sign up for free tier or pro tier (~$80/mo).
ODDS_API_KEY=your_odds_api_key_here

# Weather API (optional -- OpenWeatherMap or Visual Crossing)
# Required for weather features. Free tier available.
WEATHER_API_KEY=your_weather_api_key_here

# Override date for the pipeline (optional)
# MLB_DATE=2026-04-15
